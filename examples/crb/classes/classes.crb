class Person {
	function init(name, age, job) {
		this.name = name;
		this.age = age;
		this.job = job;
	}

	function print_person() {
		printf("Name: %, Age: %, Job: %\n", this.name, this.age, this.job);
	}
}

def john = Person("John", 24, "Artist");
def eric = Person("Eric", 42, "Doctor");
def peter = Person("Peter", 31, "Police Officer");

john.print_person();
eric.print_person();
peter.print_person();