profiler.start("testing_two_loops");

def i;
def j;

for(i = 0; i < 25000; i = i + 1) { }
for(j = 0; j < 25000; j = j + 1) { }

profiler.end("testing_two_loops");
printf("First run - %", profiler.report());

i = 0;
j = 0;

profiler.start("testing_two_loops");

while(i < 50000) { i = i + 1; }
while(j < 50000) { j = j + 1; }

profiler.end("testing_two_loops");
printf("Second run - %", profiler.report());