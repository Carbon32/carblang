class Person {
	function init(name, age) {
		class Human {
			function init(name, age) {
				this.name = name;
				this.age = age;
			}

			function print_values() {
				printf("Name: %\nAge: %", this.name, this.age);
			}
		}

		this.human = Human(name, age);
	}
}

def p = Person("John", 28);
p.human.print_values();