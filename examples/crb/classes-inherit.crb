class Person {
	function init(name) {
		this.name = name;
	}

	function get_name() {
		return "Name: John";
	}

	function get_age() {
		return "Age: 28";
	}

	function get_job() {
		return "Job: Miner";
	}
}

class Worker : Person {
	function print_name() {
		printf("The name is %\n", this.name);
	}
}

def john = Worker("John");
printf("%, %, %\n", john.get_name(), john.get_age(), john.get_job());
john.print_name();
