def x = 5;
def y = 2;

def a = 3;
def b = 6;

def c = 9;
def d = 9;

if(x > y) {
	println("X is bigger than Y");
}
else {
	println("Y is bigger than X");
}

if(a > b) {
	println("A is bigger than B");
}
else {
	println("B is bigger than A");
}

if(c == d) {
	println("C contains the same value as D");
}
else {
	println("C and D contain different values");
}

