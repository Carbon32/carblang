file.write("hello.txt", "Hello World");

def x = file.read("hello.txt");
println(x);

file.append("hello.txt", "\nHere is more text");
x = file.read("hello.txt");
println(x);

def i;
for(i = 0; i < 5; i = i + 1) {
	file.append("hello.txt", "\nText: " + i);
}

x = file.read("hello.txt");
println(x);

file.erase("hello.txt");